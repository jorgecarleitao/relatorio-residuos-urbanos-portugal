FROM jbarlow83/ocrmypdf:latest

# Install pdftotext (from poppler-utils) for text extraction
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    poppler-utils \
    bash && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /work

# Copy the wrapper script
COPY ocr/pdf2txt.sh /usr/local/bin/pdf2txt
RUN chmod +x /usr/local/bin/pdf2txt

ENTRYPOINT ["pdf2txt"]
